{
	"name": "backend",
	"main": "./index.js",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "bun run ./built/index.js",
		"start:dev": "bun --watch ./src/index.ts",
		"start:debug": "bun --inspect ./built/index.js",
		"start:test": "NODE_ENV=test bun run ./built/index.js",
		"migrate": "bunx typeorm migration:run -d built/ormconfig.js",
		"revertmigration": "bunx typeorm migration:revert -d built/ormconfig.js",
		"generatemigration": "bun run build && bunx typeorm migration:generate -d built/ormconfig.js",
		"build": "bunx swc src -d built -D",
		"build:debug": "bunx swc src -d built -s -D",
		"watch": "bun --watch ./src/index.ts",
		"lint": "biome check --apply *",
		"format": "biome format * --write"
	},
